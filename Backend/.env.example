# =============================================================
# Database Settings (PostgreSQL)
# =============================================================
# On Render: Dashboard > Environment > Add Environment Variable
# If using Render PostgreSQL, DATABASE_URL is provided automatically.

DATABASE_URL=postgresql://user:password@host:5432/blockchain_voting

# Individual settings (for local development):
# DB_USER=postgres
# DB_PASSWORD=your_password
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=blockchain_voting

# =============================================================
# JWT (Token) Settings [REQUIRED]
# =============================================================
# Must be at least 32 characters. Generate a random one with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-this-to-a-strong-secret-at-least-32-chars

# =============================================================
# Admin User Password
# =============================================================
# Password for the default admin account. Defaults to admin123 if not set.
# Always change this in production!
ADMIN_PASSWORD=strong-admin-password

# =============================================================
# Server Settings
# =============================================================
PORT=3000

# =============================================================
# CORS - Frontend URL
# =============================================================
# Set this to your frontend URL after deploying to Netlify.
# Example: https://blockchain-voting.netlify.app
FRONTEND_URL=http://localhost:3001
